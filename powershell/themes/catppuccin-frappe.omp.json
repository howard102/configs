{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "diamond",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b0",
          "foreground": "#303446",
          "background": "#A6D189",
          "template": " {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#303446",
          "background": "#8CAAEE",
          "properties": {
            "style": "folder"
          },
          "template": " \uf07b {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#303446",
          "background": "#CA9EE6",
          "properties": {
            "branch_icon": "\ue725 ",
            "fetch_status": true
          },
          "template": " {{ .HEAD }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }} "
        },
        {
          "type": "text",
          "style": "diamond",
          "leading_diamond": "\ue0b0",
          "trailing_diamond": "\ue0b4",
          "foreground": "#303446",
          "background": "#E5C890",
          "template": " pwsh "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#E78284{{ else }}#A6D189{{ end }}"
          ],
          "template": "\u279c "
        }
      ]
    }
  ]
}